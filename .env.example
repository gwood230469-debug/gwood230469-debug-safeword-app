EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# From Google Cloud Console > APIs & Services > Credentials.
# webClientId: the "Web application" OAuth client ID (also goes into Supabase's Google provider config).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS OAuth client's ID, reversed into a URL scheme: com.googleusercontent.apps.YOUR-IOS-CLIENT-ID
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# Optional. Public URL of the hosted web/invite-redirect/index.html landing
# page (see web/invite-redirect/README.md) — shown to someone who taps an
# invite link without the app installed yet, with store links, before it
# redirects into the app for people who do have it. Leave blank and
# buildInviteUrl() falls back to the bare safeword://invite/<token> deep
# link, exactly as before this page existed.
EXPO_PUBLIC_INVITE_LANDING_URL=
